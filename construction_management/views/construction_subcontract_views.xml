<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Subcontract List View -->
    <record id="view_construction_subcontract_list" model="ir.ui.view">
        <field name="name">construction.subcontract.list</field>
        <field name="model">construction.subcontract</field>
        <field name="arch" type="xml">
            <list>
                <field name="ref"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="subcontractor_id"/>
                <field name="wbs_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="contract_value"/>
                <field name="amount_paid"/>
                <field name="amount_remaining"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'completed'"
                    decoration-primary="state == 'active'"
                    decoration-danger="state == 'terminated'"
                    decoration-muted="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- Subcontract Form View -->
    <record id="view_construction_subcontract_form" model="ir.ui.view">
        <field name="name">construction.subcontract.form</field>
        <field name="model">construction.subcontract</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" type="object" string="Activate"
                        invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_complete" type="object" string="Complete"
                        invisible="state != 'active'" class="btn-primary"/>
                    <button name="action_terminate" type="object" string="Terminate"
                        invisible="state not in ('draft', 'active')"/>
                    <button name="action_reset" type="object" string="Reset to Draft"
                        invisible="state != 'terminated'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                        <div><field name="ref" readonly="1"/></div>
                    </div>
                    <group>
                        <group string="Contract Details">
                            <field name="project_id"/>
                            <field name="wbs_id"/>
                            <field name="subcontractor_id"/>
                        </group>
                        <group string="Contract Dates">
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <group string="Financials">
                        <group>
                            <field name="contract_value"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="retention_percent"/>
                            <field name="retention_amount" readonly="1"/>
                        </group>
                        <group>
                            <field name="amount_paid"/>
                            <field name="amount_remaining" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Scope of Work">
                            <field name="scope_of_work"/>
                        </page>
                        <page string="Payment Terms">
                            <field name="payment_terms"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Subcontract Action -->
    <record id="action_construction_subcontract" model="ir.actions.act_window">
        <field name="name">Subcontracts</field>
        <field name="res_model">construction.subcontract</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
